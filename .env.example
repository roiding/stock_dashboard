# 方式一: 拆分字段 (推荐, 密码含特殊字符自动编码)
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=stock_dashboard

# 方式二: 整串 (覆盖上面的拆分字段)
# DATABASE_URL=mysql+pymysql://user:password@host:3306/stock_dashboard

STOCK_DATA_DIR=/data
API_BASE_URL=http://localhost:5000
SECRET_KEY=change-me-in-production
FLASK_DEBUG=0
